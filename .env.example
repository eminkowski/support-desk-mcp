# Copy with `pnpm env:copy` into apps/api/.env, apps/mcp-server/.env, and apps/web/.env
# Each app reads only the variables it needs (see README).

# --- apps/api only (required for Prisma + API) ---
DATABASE_URL=postgresql://supportdesk:supportdesk@localhost:5433/supportdesk
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- apps/api + apps/mcp-server ---
API_KEY=local-dev-api-key

# --- apps/api only (optional Claude assist for Ask the queue free-text) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- apps/mcp-server only (HTTP client to the API; no database) ---
API_BASE_URL=http://localhost:3001
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3002

# --- apps/web only (Vite; no database) ---
VITE_API_BASE_URL=http://localhost:3001
VITE_API_KEY=local-dev-api-key
